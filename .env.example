# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub!
# ─────────────────────────────────────────────────────

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ecommercedb?retryWrites=true&w=majority

# JWT Secret Key (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long

# JWT Token Expiry (in milliseconds → 86400000 = 24 hours)
JWT_EXPIRATION=86400000

# Server Port
PORT=8080
